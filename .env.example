# Live MySQL database (Hostinger). On the server the DB is reachable at
# localhost; copy this file to .env.local and fill in the real values.
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Set to "sqlfile" to read articles from the bundled SQL dump instead of MySQL
# (useful for local development where the live DB is not reachable).
# ARTICLES_SOURCE=sqlfile
