# Live MySQL database (Hostinger). On the server the DB is reachable at the
# IPv4 loopback. Use 127.0.0.1 (NOT "localhost") — "localhost" can resolve to
# IPv6 "::1", which the DB user grant doesn't cover, giving "Access denied
# for user …@'::1'". Copy this file to .env.local and fill in the real values.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Set to "sqlfile" to read articles/batches from the bundled SQL dump instead of
# MySQL (useful for local development where the live DB is not reachable).
# ARTICLES_SOURCE=sqlfile

# Razorpay payment keys for the student admission panel (/student-admission-panel).
# Without these, the panel still records registrations but shows a "pay link to
# follow" message instead of charging.
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
