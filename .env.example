# Live MySQL database (Hostinger). On the server the DB is reachable at the
# IPv4 loopback. Use 127.0.0.1 (NOT "localhost") — "localhost" can resolve to
# IPv6 "::1", which the DB user grant doesn't cover, giving "Access denied
# for user …@'::1'". Copy this file to .env.local and fill in the real values.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Set to "sqlfile" to read articles/batches from the bundled SQL dump instead of
# MySQL (useful for local development where the live DB is not reachable).
# ARTICLES_SOURCE=sqlfile

# Razorpay payment keys for the student admission panel (/student-admission-panel).
# Without these, the panel still records registrations but shows a "pay link to
# follow" message instead of charging.
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx

# PayPal (admission panel). Create a REST app at developer.paypal.com → My Apps
# & Credentials → Live, then copy its Client ID and Secret. The Client ID is also
# needed client-side to render the PayPal buttons, hence the NEXT_PUBLIC_ copy.
# Set PAYPAL_ENV=sandbox to test against PayPal's sandbox instead of live.
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_ENV=live

# Contact form email (Gmail SMTP). Create a Gmail App Password for info@adhiroha.com.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=info@adhiroha.com
SMTP_PASS=your-gmail-app-password
CONTACT_TO=info@adhiroha.com

# Where new-registration notifications are sent (the admission panel).
ADMISSION_NOTIFY_TO=2yinfotech@gmail.com
