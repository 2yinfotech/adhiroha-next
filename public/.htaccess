# Adhiroha — static hosting rules (Apache / Hostinger hPanel)

RewriteEngine On

# --- Redirect legacy .html URLs to the new clean URLs (301, SEO-safe) ---
# /index.html            -> /
RewriteCond %{THE_REQUEST} \s/index\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]
# /about-us.html, /200-hour-....html, ...  -> /about-us/ , /200-hour-.../ ...
RewriteCond %{THE_REQUEST} \s/([^\s?]+)\.html[\s?] [NC]
RewriteRule ^ /%1/ [R=301,L]

# --- Serve the exported per-route index.html for extension-less URLs ---
# (Next.js export with trailingSlash writes <route>/index.html, which Apache
#  serves automatically; this is just a safety net.)
DirectoryIndex index.html

# --- Custom 404 page generated by the export ---
ErrorDocument 404 /404.html

# --- Long-cache the immutable Next.js build assets ---
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|webp|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
